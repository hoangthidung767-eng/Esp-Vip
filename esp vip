-- LOGIC SỰ KIỆN ESP
local function addESP(c)
    if not c or c:FindFirstChild("CRAB_RAINBOW_ESP") then return end
    local p = A:GetPlayerFromCharacter(c)
    if p == C then return end
    local h = Instance.new("Highlight", c)
    h.Name, h.FillColor, h.OutlineColor, h.FillTransparency, h.OutlineTransparency = "CRAB_RAINBOW_ESP", Color3.fromRGB(255, 0, 0), Color3.fromRGB(255, 255, 255), 0.4, 0
end

local function removeESP(c) if c and c:FindFirstChild("CRAB_RAINBOW_ESP") then c.CRAB_RAINBOW_ESP:Destroy() end end

task.spawn(function()
    while true do 
        for _, p in pairs(A:GetPlayers()) do 
            if p.Character then 
                if T and p ~= C then addESP(p.Character) else removeESP(p.Character) end 
            end 
        end
        task.wait(0.5)
    end 
end)

A.PlayerRemoving:Connect(function(p) if p.Character then removeESP(p.Character) end end)
