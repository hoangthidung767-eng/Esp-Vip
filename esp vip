local function createInputField(labelTitle, defaultVal, yPos)
    local container = Instance.new("Frame", G)
    container.Size, container.Position, container.BackgroundTransparency = UDim2.new(1, -20, 0, 35), UDim2.new(0, 10, 0, yPos), 1
    
    local label = Instance.new("TextLabel", container)
    label.Size, label.Text, label.TextColor3, label.TextXAlignment, label.BackgroundTransparency, label.Font, label.TextSize = UDim2.new(0, 100, 1, 0), labelTitle, Color3.fromRGB(255, 255, 255), Enum.TextXAlignment.Left, 1, Enum.Font.SourceSansBold, 13
    
    local box = Instance.new("TextBox", container)
    box.Size, box.Position, box.Text, box.BackgroundColor3, box.TextColor3, box.Font, box.TextSize = UDim2.new(0, 80, 0, 25), UDim2.new(1, -80, 0.5, -12), tostring(defaultVal), Color3.fromRGB(40, 40, 40), Color3.fromRGB(255, 255, 255), Enum.Font.SourceSansBold, 13
    box.ClearTextOnFocus = false
    local CornerBox = Instance.new("UICorner", box) CornerBox.CornerRadius = UDim.new(0, 4)
    
    local StrokeBox = Instance.new("UIStroke", box)
    StrokeBox.Thickness = 1
    StrokeBox.Color = Color3.fromRGB(70, 70, 70)
    
    return box
end

