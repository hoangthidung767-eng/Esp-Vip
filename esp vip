-- THUẬT TOÁN KÉO THẢ DI CHUYỂN MENU MƯỢT MÀ -------
----------------------------------------------------
local dragging, dragInput, dragStart, startPos
local TweenService = game:GetService("TweenService")

local function update(input)
    local delta = input.Position - dragStart
    local targetPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    TweenService:Create(G, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = targetPos}):Play()
end

H.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = G.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

H.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
end)

B.InputChanged:Connect(function(input)
    if input == dragInput and dragging then update(input) end
end)

F.MouseButton1Click:Connect(function() G.Visible = not G.Visible end)

